---
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__content">
      <p class="hero__eyebrow">Salon de coiffure — Béziers</p>
      <h1 class="hero__title">
        Votre beauté,<br />
        <em>sublimée au naturel</em>
      </h1>
      <p class="hero__text">
        Colorations végétales, coupes femmes et soins douceur —
        dans un salon intimiste à Béziers, uniquement sur rendez-vous.
      </p>
      <div class="hero__actions">
        <a href="#contact" class="btn btn--primary">Prendre rendez-vous</a>
        <a href="#prestations" class="btn btn--outline">Voir les prestations</a>
      </div>
    </div>

    <div class="hero__visual">
      <div class="hero__image-wrap">
        <div class="hero__image-placeholder" aria-hidden="true">
          <span>Photo à intégrer</span>
        </div>
      </div>
      <div class="hero__badge" aria-hidden="true">
        <span class="hero__badge-icon">✦</span>
        <span>Colorations<br />végétales</span>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/foundations' as *;

  .hero {
    background-color: $color-bg;
    padding-block: clamp(3.5rem, 7vw, 6rem);

    &__inner {
      display: grid;
      gap: 3rem;
      align-items: center;

      @include respond-to('lg') {
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
      }
    }

    &__eyebrow {
      font-size: 0.82rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: $color-secondary;
      font-weight: 600;
      margin-bottom: 1.25rem;
    }

    &__title {
      font-size: clamp(2.4rem, 5vw, 3.8rem);
      font-weight: 400;
      line-height: 1.1;
      margin-bottom: 1.25rem;
      color: $color-text;

      em {
        font-style: italic;
        color: $color-accent-dark;
      }
    }

    &__text {
      font-size: 1.05rem;
      color: $color-text-muted;
      line-height: 1.8;
      margin-bottom: 2rem;
      max-width: 440px;
    }

    &__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
    }

    &__visual {
      position: relative;

      @include respond-to('lg') {
        order: 2;
      }
    }

    &__image-wrap {
      border-radius: $radius-lg;
      overflow: hidden;
      aspect-ratio: 4 / 5;
    }

    &__image-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: $color-text-muted;
      font-size: 0.9rem;
      background: linear-gradient(145deg, $color-accent-bg 0%, $color-secondary-bg 100%);
    }

    &__badge {
      position: absolute;
      bottom: 1rem;
      left: 1rem;
      background: white;
      border: 1px solid $color-border;
      border-radius: $radius-md;
      box-shadow: $shadow-md;
      padding: 0.9rem 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.85rem;
      font-weight: 600;
      color: $color-text;
      line-height: 1.35;

      @include respond-to('lg') {
        bottom: -1.5rem;
        left: -1rem;
      }
    }

    &__badge-icon {
      font-size: 1.1rem;
      color: $color-secondary;
    }
  }
</style>
